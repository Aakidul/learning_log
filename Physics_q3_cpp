#include <iostream>
using namespace std;

/*
Question 3:

The mass of first ball = m1 = 50g = 0.05kg,
mass of the second ball = m2 = 100 = 0.1kg
intial velocity of the first ball = u1 = 3m/s
intial velocity of the second ball = u2 = 1.5m/s
final velocity of the first ball = v1 = 2.5m/s,
final velocity of the second ball = v2 = ?


*/



double q3(double m1, double m2, double v1, double u1, double u2){
    // After collison v1 = 2.5m/s, v2 = ?

    m1 = m1/1000;
    m2 = m2/1000;


    // As per law of conservation
    // (M1•U1) + (M2•U2) = (M1•V1) + (M2• V2)
    double l1 = m1 * u1;
    double l2 = m2 * u2;

    double initial = l1 + l2;

    double l3 = m1 * v1;
    double l4 = m2;

    double final = l3;
    double v2 = (initial - final) / l4;
    return v2;

}

int main(){
    double a = q3(50, 100, 2.5, 3, 1.5);
    cout << a << " m/s" << endl;
    return 0;

}
